generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  username     String
  createdAt    DateTime      @default(now())
  roundResults RoundResult[]
  matchResults MatchResult[]
}

model Match {
  id           String        @id @default(uuid())
  code         String        @unique
  status       MatchStatus   @default(WAITING)
  createdAt    DateTime      @default(now())
  roundResults RoundResult[]
  matchResults MatchResult[]
}

enum MatchStatus {
  WAITING
  ACTIVE
  FINISHED
}

model RoundResult {
  id       String @id @default(uuid())
  matchId  String
  roundId  String
  playerId String
  guessedX Float
  guessedZ Float
  trueX    Float
  trueZ    Float
  distance Float
  score    Int
  accuracy Float

  match  Match @relation(fields: [matchId], references: [id])
  player User  @relation(fields: [playerId], references: [id])

  @@unique([matchId, roundId, playerId])
}

model MatchResult {
  id          String @id @default(uuid())
  matchId     String
  playerId    String
  totalScore  Int
  avgAccuracy Float

  match  Match @relation(fields: [matchId], references: [id])
  player User  @relation(fields: [playerId], references: [id])

  @@unique([matchId, playerId])
}
